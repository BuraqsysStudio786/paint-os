generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Prisma 7 reads connection URLs from prisma.config.ts. DATABASE_URL is used
// by the runtime PostgreSQL adapter; DIRECT_URL is used by Prisma CLI commands.

enum Role {
  SUPER_ADMIN
  AGENCY_ADMIN
  CLIENT_ADMIN
  SALES
  EDITOR
  VIEWER
}

enum PriceMode {
  hidden
  quote
  show
  ecommerce
}

enum DocumentType {
  brochure
  shade_card
  tds
  sds
  application_guide
  warranty
  certificate
}

enum ImportType {
  products
  shades
  dealers
}

enum ImportStatus {
  uploaded
  validating
  completed
  failed
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  clientId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id String @id @default(cuid())
  name String
  slug String @unique
  tagline String
  description String
  logoUrl String?
  logoLightUrl String?
  logoDarkUrl String?
  faviconUrl String?
  primaryColor String
  secondaryColor String
  accentColor String
  backgroundColor String
  surfaceColor String
  textColor String
  mutedTextColor String
  headingFont String @default("Playfair Display")
  bodyFont String @default("Manrope")
  buttonStyle String @default("soft")
  cardStyle String @default("editorial")
  themePreset String @default("premium-home")
  tone String
  whatsappNumber String
  phone String
  email String
  website String?
  address String?
  city String
  state String?
  country String
  zipCode String?
  facebookUrl String?
  instagramUrl String?
  youtubeUrl String?
  linkedinUrl String?
  tiktokUrl String?
  customDomain String? @unique
  isActive Boolean @default(true)
  demoMode Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  featureFlag FeatureFlag?
  homepageSections HomepageSection[]
  categories ProductCategory[]
  products Product[]
  productFeatures ProductFeature[]
  applicationSteps ApplicationStep[]
  shades Shade[]
  rooms Room[]
  visualizerSpaces VisualizerSpace[]
  dealers Dealer[]
  painters Painter[]
  leads Lead[]
  quotes Quote[]
  documents Document[]
  blogPosts BlogPost[]
  faqs FAQ[]
  testimonials Testimonial[]
  projects Project[]
  aiSessions AISession[]
  importJobs ImportJob[]
  visualizerProjects VisualizerProject[]
  favorites Favorite[]
  socialLinks SocialLink[]
}

model FeatureFlag {
  id String @id @default(cuid())
  clientId String @unique
  visualizerEnabled Boolean @default(true)
  calculatorEnabled Boolean @default(true)
  productFinderEnabled Boolean @default(true)
  colorConsultantEnabled Boolean @default(true)
  problemSolverEnabled Boolean @default(true)
  dealerLocatorEnabled Boolean @default(true)
  painterBookingEnabled Boolean @default(true)
  ecommerceEnabled Boolean @default(false)
  quoteModeEnabled Boolean @default(true)
  blogEnabled Boolean @default(true)
  projectsEnabled Boolean @default(true)
  technicalLibraryEnabled Boolean @default(true)
  aiContentEnabled Boolean @default(true)
  shadeCardDigitizerEnabled Boolean @default(true)
  importEnabled Boolean @default(true)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model HomepageSection {
  id String @id @default(cuid())
  clientId String
  key String
  sectionType String
  title String
  eyebrow String?
  subtitle String?
  content String?
  imageUrl String?
  backgroundImageUrl String?
  ctaLabel String?
  ctaUrl String?
  secondaryCtaLabel String?
  secondaryCtaUrl String?
  order Int
  isEnabled Boolean @default(true)
  configJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, key])
}

model ProductCategory {
  id String @id @default(cuid())
  clientId String
  name String
  slug String
  description String
  imageUrl String?
  iconKey String @default("PaintBucket")
  order Int @default(0)
  isActive Boolean @default(true)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  products Product[]
  documents Document[]
  @@unique([clientId, slug])
}

model Product {
  id String @id @default(cuid())
  clientId String
  categoryId String
  name String
  slug String
  sku String?
  subtitle String
  shortDescription String
  longDescription String
  imageUrl String?
  bucketImageUrl String?
  heroImageUrl String?
  galleryJson Json
  finish String
  sheenLevel String
  surface String
  productType String
  spacesJson Json @default("[]")
  colorFamiliesJson Json @default("[]")
  waterBased Boolean @default(true)
  oilBased Boolean @default(false)
  interiorExterior String
  coverageSqftPerLiterOneCoat Float
  coverageSqftPerLiterTwoCoat Float
  recommendedCoats Int
  dryingTime String
  recoatTime String
  applicationToolsJson Json
  packSizesJson Json
  featuresJson Json
  benefitsJson Json
  recommendedSystemJson Json
  availableShadeIdsJson Json
  warrantyYears Int?
  priceMode PriceMode @default(quote)
  startingPrice Float?
  currency String @default("PKR")
  tdsUrl String?
  sdsUrl String?
  brochureUrl String?
  applicationGuideUrl String?
  isFeatured Boolean @default(false)
  isNew Boolean @default(false)
  isBestSeller Boolean @default(false)
  seoTitle String?
  seoDescription String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productFeatures ProductFeature[]
  applicationSteps ApplicationStep[]
  documents Document[]
  faqs FAQ[]
  testimonials Testimonial[]
  @@unique([clientId, slug])
  @@unique([clientId, sku])
  @@index([clientId, categoryId])
}

model ProductFeature {
  id String @id @default(cuid())
  clientId String
  productId String
  title String
  description String
  iconKey String
  imageUrl String?
  order Int
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ApplicationStep {
  id String @id @default(cuid())
  clientId String
  productId String
  stepNumber Int
  title String
  productName String
  coats Int
  tool String
  description String
  iconKey String
  order Int
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Shade {
  id String @id @default(cuid())
  clientId String
  name String
  slug String
  code String
  hex String
  rgb String
  colorFamily String
  temperature String
  mood String
  lightness String
  season String?
  spacesJson Json @default("[]")
  bestRoomsJson Json
  matchingShadeIdsJson Json
  collection String
  finishAvailabilityJson Json
  productIdsJson Json
  description String
  isTrending Boolean @default(false)
  isColorOfYear Boolean @default(false)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  visualizerSpaces VisualizerSpace[]
  visualizerProjects VisualizerProject[]
  favorites Favorite[]
  @@unique([clientId, slug])
  @@unique([clientId, code])
}

model Room {
  id String @id @default(cuid())
  clientId String
  name String
  slug String
  description String
  imageUrl String
  roomType String
  space String?
  dominantColorFamily String?
  recommendedShadeIdsJson Json
  recommendedProductIdsJson Json
  designTips String
  order Int
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, slug])
}

model VisualizerSpace {
  id String @id @default(cuid())
  clientId String
  name String
  slug String
  roomType String
  space String?
  imageUrl String
  thumbnailUrl String
  maskJson Json
  defaultShadeId String?
  isFeatured Boolean @default(false)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  defaultShade Shade? @relation(fields: [defaultShadeId], references: [id], onDelete: SetNull)
  visualizerProjects VisualizerProject[]
  @@unique([clientId, slug])
}

model Dealer {
  id String @id @default(cuid())
  clientId String
  name String
  slug String?
  city String
  state String?
  area String
  zipCode String?
  address String
  phone String
  whatsapp String
  email String?
  latitude Float?
  longitude Float?
  availableProductCategoryIdsJson Json
  openingHours String
  managerName String?
  isFeatured Boolean @default(false)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, slug])
}

model Painter {
  id String @id @default(cuid())
  clientId String
  name String
  city String
  area String
  phone String
  whatsapp String
  skillsJson Json
  rating Float
  completedProjects Int
  isApproved Boolean @default(false)
  isActive Boolean @default(true)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Lead {
  id String @id @default(cuid())
  clientId String
  name String
  phone String
  email String?
  city String?
  area String?
  source String
  status String @default("new")
  message String?
  selectedProductId String?
  selectedShadeId String?
  estimatedArea Float?
  estimatedLiters Float?
  estimatedBudget Float?
  assignedDealerId String?
  assignedPainterId String?
  metadataJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quotes Quote[]
  aiSessions AISession[]
  visualizerProjects VisualizerProject[]
}

model Quote {
  id String @id @default(cuid())
  clientId String
  leadId String?
  productIdsJson Json
  shadeIdsJson Json
  roomDetailsJson Json
  surfaceDetailsJson Json
  totalArea Float
  totalLiters Float
  estimatedMaterialCost Float?
  estimatedLaborCost Float?
  totalEstimate Float?
  pdfUrl String?
  status String @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model Document {
  id String @id @default(cuid())
  clientId String
  title String
  type DocumentType
  fileUrl String
  productId String?
  categoryId String?
  description String
  createdAt DateTime @default(now())
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model BlogPost {
  id String @id @default(cuid())
  clientId String
  title String
  slug String
  excerpt String
  content String
  imageUrl String
  category String
  tagsJson Json
  seoTitle String
  seoDescription String
  isPublished Boolean @default(false)
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, slug])
}

model FAQ {
  id String @id @default(cuid())
  clientId String
  productId String?
  question String
  answer String
  order Int
  isActive Boolean @default(true)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id String @id @default(cuid())
  clientId String
  name String
  city String
  rating Int
  quote String
  productId String?
  imageUrl String?
  isFeatured Boolean @default(false)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Project {
  id String @id @default(cuid())
  clientId String
  title String
  slug String
  description String
  city String
  projectType String
  beforeImageUrl String
  afterImageUrl String
  galleryJson Json
  productIdsJson Json
  shadeIdsJson Json
  clientName String
  completionDate DateTime
  isFeatured Boolean @default(false)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, slug])
}

model AISession {
  id String @id @default(cuid())
  clientId String
  type String
  inputJson Json
  outputJson Json
  leadId String?
  createdAt DateTime @default(now())
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model ImportJob {
  id String @id @default(cuid())
  clientId String
  type ImportType
  fileName String
  status ImportStatus
  totalRows Int
  importedRows Int
  failedRows Int
  errorJson Json?
  createdAt DateTime @default(now())
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rowErrors ImportRowError[]
}

model ImportRowError {
  id String @id @default(cuid())
  importJobId String
  rowNumber Int
  field String
  message String
  rawJson Json
  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
}

model VisualizerProject {
  id String @id @default(cuid())
  clientId String
  leadId String?
  sessionId String
  spaceId String?
  uploadedImageUrl String?
  shadeId String
  maskJson Json
  resultImageUrl String?
  createdAt DateTime @default(now())
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  space VisualizerSpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  shade Shade @relation(fields: [shadeId], references: [id], onDelete: Restrict)
}

model Favorite {
  id String @id @default(cuid())
  clientId String
  sessionId String
  shadeId String?
  productId String?
  createdAt DateTime @default(now())
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  shade Shade? @relation(fields: [shadeId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id String @id @default(cuid())
  clientId String
  platform String
  url String
  iconKey String
  isActive Boolean @default(true)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, platform])
}
